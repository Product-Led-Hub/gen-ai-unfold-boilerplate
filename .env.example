# ============================================================
# Gen AI Bootcamp — Environment Variables
# Copy this file to .env.local and fill in your values.
# Only the variables for the providers you use need to be set.
# ============================================================

# ── Cloud providers (Session 2 / production) ───────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── LM Studio (Session 1 — primary test environment) ──────────────────
# 1. Download LM Studio from https://lmstudio.ai
# 2. Search and download: llama-3.2-3b-instruct
# 3. Go to the Local Server tab, select the model, click Start Server
# 4. Server runs on port 1234 (OpenAI-compatible API)
# The API key can be any non-empty string — LM Studio ignores it.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# ── Ollama (alternative local provider) ───────────────────────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Start:   ollama serve
# Models:  ollama pull llama3.2   |   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── RAG embedding models (Session 3) ────────────────────────────────
# Cloud:  uses OPENAI_API_KEY above, model = text-embedding-3-small
# Local:  install in Ollama:
#   ollama pull nomic-embed-text   (768 dims, fast, recommended for local)
#   ollama pull mxbai-embed-large  (1024 dims, higher quality)
# Switch the embedding provider from the UI Features panel.
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=nomic-embed-text
